/dts-v1/;
/plugin/;

&i2c2 {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    scd30@61 { compatible = "sensirion,scd30"; reg = <0x61>; };

    sgp30@58 { compatible = "sensirion,sgp30"; reg = <0x58>; };

    bmp580@47 { compatible = "bosch,bmp580";  reg = <0x47>; };

    peripheral_ina219: ina219-peripheral@40 { // Peripheral current monitor
        compatible = "ti,ina219";     
        reg = <0x40>; 
        shunt-resistor = <100000>; // (microohms) -> 0.1 Ohm
    };

    system_ina219: ina219-system@41 { // System current monitor
        compatible = "ti,ina219";
        reg = <0x41>; 
        shunt-resistor = <100000>; // (microohms) -> 0.1 Ohm
    };

    rtc@68 { 
        compatible = "maxim,ds3231";  
        reg = <0x68>; 
    };
};